# .gitignore

# Environment variables - NEVER push this to GitHub
.env
.env.local
.env.production

# Node modules - too large to push
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Video uploads (store on cloud)
uploads/
*.mp4
*.mkv
*.avi
*.mov
*.webm

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
logs/
*.log

# Build files
dist/
build/

# Cache
.cache/
.npm/